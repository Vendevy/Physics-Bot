# Claude API key — used for question generation and grading (high quality reasoning)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Extraction API — used for building the question bank from past papers
# Works with any OpenAI-compatible provider: OpenCode GO, Together, Fireworks, etc.
# Get your key from your provider's dashboard.
EXTRACT_API_KEY=sk-...
EXTRACT_BASE_URL=https://api.opencode.gg/v1  # or your provider's base URL
EXTRACT_MODEL=minimax-m2.5  # cheapest option on OpenCode GO

# Alternative cheap models on OpenCode GO:
# EXTRACT_MODEL=deepseek-v4-flash
# EXTRACT_MODEL=qwen3.5-plus
# EXTRACT_MODEL=kimi-k2.5
